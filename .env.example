# ============================================
# ReelForge AI - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Database (MySQL)
DATABASE_URL="mysql://user:password@host:3306/reelforge_ai"

# NextAuth.js
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32
AUTH_SECRET=""       # Same as NEXTAUTH_SECRET

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID="price_..."

# Redis
REDIS_URL="redis://default:password@host:6379"

# AI APIs
ANTHROPIC_API_KEY="sk-ant-..."
AI_PROVIDER="gemini"
NEXT_PUBLIC_AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
LLM_FALLBACK="on"

# Video Generation
RUNWAY_API_KEY=""
LUMA_API_KEY=""
REPLICATE_API_KEY=""

# Stock Footage
PEXELS_API_KEY=""

# Voice / TTS
ELEVENLABS_API_KEY=""

# Storage (Cloudflare R2)
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="reelforge-videos"
CDN_URL="https://cdn.yourdomain.com"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="ReelForge AI <noreply@yourdomain.com>"

# Worker
WORKER_SECRET=""  # Generate with: openssl rand -hex 32
WORKER_CALLBACK_URL="https://your-domain.vercel.app/api/webhooks/worker"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD=""
NODE_ENV="production"

# Set to "false" in production to use real AI video generation
DEV_MODE="false"
