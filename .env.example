# ============================================
# ReelForge AI - Environment Variables
# ============================================

# Database (PlanetScale MySQL)
DATABASE_URL="mysql://root:root@host:3306/reelforge_ai"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID="price_..."

# Redis (Upstash)
REDIS_URL="redis://localhost:6379"

# AI APIs
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
RUNWAY_API_KEY=""
ELEVENLABS_API_KEY=""

# Storage (Cloudflare R2 / AWS S3)
R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="reelforge-videos"
CDN_URL="https://cdn.reelforge.ai"

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="ReelForge AI <noreply@reelforge.ai>"

# Worker
WORKER_SECRET="your-worker-shared-secret"
WORKER_CALLBACK_URL="http://localhost:3000/api/webhooks/worker"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NODE_ENV="development"
