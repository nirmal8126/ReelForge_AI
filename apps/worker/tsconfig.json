{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": { "@reelforge/db": ["../../packages/db/src"] }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
