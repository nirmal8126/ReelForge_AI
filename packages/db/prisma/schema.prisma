// Challenge / Game Reels
model ChallengeJob {
  id               String              @id @default(cuid())
  userId           String              @map("user_id")

  // Content settings
  challengeType    String              @map("challenge_type") @db.VarChar(30)    // emoji_guess, riddle, math, gk_quiz, would_you_rather
  category         String              @db.VarChar(50)                           // kids, students, gk, bollywood, fun
  difficulty       String              @default("medium") @db.VarChar(20)        // easy, medium, hard, impossible
  numQuestions     Int                 @default(3) @map("num_questions")         // 1, 3, 5
  timerSeconds     Int                 @default(5) @map("timer_seconds")         // 5, 10, 15
  language         String              @default("hi") @db.VarChar(10)
  prompt           String?             @db.Text                                  // optional custom topic/context

  // Visual & audio
  templateStyle    String              @default("neon") @map("template_style") @db.VarChar(30)
  voiceEnabled     Boolean             @default(false) @map("voice_enabled")
  voiceId          String?             @map("voice_id") @db.VarChar(100)

  // Generated content
  questionsJson    String?             @map("questions_json") @db.LongText       // AI-generated questions/answers as JSON
  ctaText          String?             @map("cta_text") @db.VarChar(300)

  // Status & progress
  status           ChallengeJobStatus  @default(QUEUED)
  progress         Int                 @default(0)
  currentStage     String?             @map("current_stage") @db.VarChar(50)

  // Output
  outputUrl        String?             @map("output_url") @db.VarChar(500)
  thumbnailUrl     String?             @map("thumbnail_url") @db.VarChar(500)

  // Metadata
  errorMessage     String?             @map("error_message") @db.Text
  creditsCost      Int                 @default(1) @map("credits_cost")
  processingTimeMs Int?                @map("processing_time_ms")

  createdAt        DateTime            @default(now()) @map("created_at")
  completedAt      DateTime?           @map("completed_at")

  user             User                @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([status])
  @@map("challenge_jobs")
}

enum ChallengeJobStatus {
  QUEUED
  CONTENT_GENERATING
  COMPOSING
  UPLOADING
  COMPLETED
  FAILED
}

// ---------------------------------------------------------------------------
// Admin Module Config — controls free/paid pricing per module
// ---------------------------------------------------------------------------
model ModuleConfig {
  id            String   @id @default(cuid())
  moduleId      String   @unique @map("module_id") @db.VarChar(50)  // reels, quotes, challenges, long_form, cartoon_studio
  moduleName    String   @map("module_name") @db.VarChar(100)
  isFree        Boolean  @default(false) @map("is_free")
  creditCost    Int      @default(1) @map("credit_cost")
  isEnabled     Boolean  @default(true) @map("is_enabled")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("module_configs")
}

// ---------------------------------------------------------------------------
// Regional Pricing — country/currency-specific plan & credit pricing
// ---------------------------------------------------------------------------
model PricingRegion {
  id             String   @id @default(cuid())
  name           String   @unique @db.VarChar(50)       // "GLOBAL", "INDIA", "SEA"
  currency       String   @db.VarChar(3)                 // "usd", "inr"
  currencySymbol String   @map("currency_symbol") @db.VarChar(5) // "$", "₹"
  countries      Json                                     // JSON array: ["IN","PK","BD"]
  isDefault      Boolean  @default(false) @map("is_default")

  planPrices   RegionPlanPrice[]
  creditPrices RegionCreditPrice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pricing_regions")
}

model RegionPlanPrice {
  id            String           @id @default(cuid())
  regionId      String           @map("region_id")
  plan          SubscriptionPlan
  priceAmount   Int              @map("price_amount")     // smallest currency unit (cents/paise)
  stripePriceId String?          @map("stripe_price_id") @db.VarChar(100)

  region PricingRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([regionId, plan])
  @@index([regionId])
  @@map("region_plan_prices")
}

model RegionCreditPrice {
  id          String @id @default(cuid())
  regionId    String @map("region_id")
  credits     Int                                      // 10, 50, 100
  priceAmount Int    @map("price_amount")
  label       String @db.VarChar(50)                   // "10 Credits"

  region PricingRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([regionId, credits])
  @@index([regionId])
  @@map("region_credit_prices")
}

// ---------------------------------------------------------------------------
// Marketing & Promotions — Banners & Announcements
// ---------------------------------------------------------------------------
model Banner {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(200)
  message      String       @db.Text
  type         BannerType   @default(INFO)
  contentType  String       @default("text") @map("content_type") @db.VarChar(10) // text | image
  targetModule String?      @map("target_module") @db.VarChar(50) // null = platform, or module id
  linkUrl      String?      @map("link_url") @db.VarChar(500)
  linkText     String?      @map("link_text") @db.VarChar(100)
  imageUrl     String?      @map("image_url") @db.VarChar(500)
  bgColor      String?      @map("bg_color") @db.VarChar(20)
  textColor    String?      @map("text_color") @db.VarChar(20)
  placement    BannerPlacement @default(DASHBOARD_TOP)
  targetPlans  Json?        @map("target_plans")       // JSON array: ["FREE","STARTER"] or null = all
  priority     Int          @default(0)                 // higher = shown first
  isActive     Boolean      @default(true) @map("is_active")
  startsAt     DateTime?    @map("starts_at")
  expiresAt    DateTime?    @map("expires_at")
  dismissible  Boolean      @default(true)
  viewCount    Int          @default(0) @map("view_count")
  clickCount   Int          @default(0) @map("click_count")

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([isActive, placement])
  @@index([startsAt, expiresAt])
  @@map("banners")
}

model PromoCode {
  id            String          @id @default(cuid())
  code          String          @unique @db.VarChar(50)
  description   String?         @db.Text
  discountType  DiscountType    @default(PERCENTAGE) @map("discount_type")
  discountValue Int             @map("discount_value")    // percentage or cents
  bonusCredits  Int             @default(0) @map("bonus_credits")
  maxUses       Int?            @map("max_uses")
  usedCount     Int             @default(0) @map("used_count")
  targetPlans   Json?           @map("target_plans")      // restrict to specific plans
  isActive      Boolean         @default(true) @map("is_active")
  startsAt      DateTime?       @map("starts_at")
  expiresAt     DateTime?       @map("expires_at")

  redemptions   PromoRedemption[]

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String    @map("promo_code_id")
  userId      String    @map("user_id")

  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([promoCodeId, userId])
  @@index([promoCodeId])
  @@index([userId])
  @@map("promo_redemptions")
}

enum BannerType {
  INFO
  SUCCESS
  WARNING
  PROMOTION
  ANNOUNCEMENT
  NEW_FEATURE
}

enum BannerPlacement {
  DASHBOARD_TOP
  DASHBOARD_BOTTOM
  SIDEBAR
  FULL_PAGE_MODAL
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  CREDIT_BONUS
}

// ---------------------------------------------------------------------------
// Notifications — in-app notification system
// ---------------------------------------------------------------------------
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  title     String           @db.VarChar(200)
  message   String           @db.Text
  type      NotificationType @default(INFO)
  linkUrl   String?          @map("link_url") @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  PROMOTION
  ANNOUNCEMENT
  NEW_FEATURE
  SYSTEM
}

// ---------------------------------------------------------------------------
// Email Campaigns — bulk marketing email system
// ---------------------------------------------------------------------------
model EmailCampaign {
  id              String              @id @default(cuid())
  name            String              @db.VarChar(200)
  subject         String              @db.VarChar(200)
  body            String              @db.LongText
  status          EmailCampaignStatus @default(DRAFT)
  targetPlans     Json?               @map("target_plans")
  targetCountries Json?               @map("target_countries")
  scheduledAt     DateTime?           @map("scheduled_at")
  sentAt          DateTime?           @map("sent_at")
  totalRecipients Int                 @default(0) @map("total_recipients")
  sentCount       Int                 @default(0) @map("sent_count")
  openCount       Int                 @default(0) @map("open_count")

  recipients EmailRecipient[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_campaigns")
}

model EmailRecipient {
  id         String               @id @default(cuid())
  campaignId String               @map("campaign_id")
  userId     String               @map("user_id")
  email      String               @db.VarChar(255)
  status     EmailRecipientStatus @default(PENDING)
  sentAt     DateTime?            @map("sent_at")
  openedAt   DateTime?            @map("opened_at")

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  @@map("email_recipients")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum EmailRecipientStatus {
  PENDING
  SENT
  OPENED
  FAILED
}

// ---------------------------------------------------------------------------
// App Settings — key-value store for global admin settings
// ---------------------------------------------------------------------------
model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
