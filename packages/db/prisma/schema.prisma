// ---------------------------------------------------------------------------
// Marketing & Promotions — Banners & Announcements
// ---------------------------------------------------------------------------
model Banner {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(200)
  message      String       @db.Text
  type         BannerType   @default(INFO)
  contentType  String       @default("text") @map("content_type") @db.VarChar(10) // text | image
  targetModule String?      @map("target_module") @db.VarChar(50) // null = platform, or module id
  linkUrl      String?      @map("link_url") @db.VarChar(500)
  linkText     String?      @map("link_text") @db.VarChar(100)
  imageUrl     String?      @map("image_url") @db.VarChar(500)
  bgColor      String?      @map("bg_color") @db.VarChar(20)
  textColor    String?      @map("text_color") @db.VarChar(20)
  placement    BannerPlacement @default(DASHBOARD_TOP)
  targetPlans  Json?        @map("target_plans")       // JSON array: ["FREE","STARTER"] or null = all
  priority     Int          @default(0)                 // higher = shown first
  isActive     Boolean      @default(true) @map("is_active")
  startsAt     DateTime?    @map("starts_at")
  expiresAt    DateTime?    @map("expires_at")
  dismissible  Boolean      @default(true)
  viewCount    Int          @default(0) @map("view_count")
  clickCount   Int          @default(0) @map("click_count")

  // Phase 3: Trigger & frequency settings
  triggerType          BannerTriggerType   @default(IMMEDIATE) @map("trigger_type")
  triggerDelay         Int?                @map("trigger_delay")           // seconds for DELAY trigger
  triggerScrollPercent Int?                @map("trigger_scroll_percent")  // 0-100 for SCROLL trigger
  showFrequency        BannerShowFrequency @default(EVERY_VISIT) @map("show_frequency")
  maxImpressions       Int?                @map("max_impressions")

  // Phase 3: A/B experiment reference
  experimentId         String?             @map("experiment_id")

  // Phase 4: Segment targeting
  targetSegmentId      String?             @map("target_segment_id")

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([isActive, placement])
  @@index([startsAt, expiresAt])
  @@map("banners")
}

model PromoCode {
  id            String          @id @default(cuid())
  code          String          @unique @db.VarChar(50)
  description   String?         @db.Text
  discountType  DiscountType    @default(PERCENTAGE) @map("discount_type")
  discountValue Int             @map("discount_value")    // percentage or cents
  bonusCredits  Int             @default(0) @map("bonus_credits")
  maxUses       Int?            @map("max_uses")
  usedCount     Int             @default(0) @map("used_count")
  targetPlans   Json?           @map("target_plans")      // restrict to specific plans
  isActive      Boolean         @default(true) @map("is_active")
  startsAt      DateTime?       @map("starts_at")
  expiresAt     DateTime?       @map("expires_at")

  redemptions   PromoRedemption[]

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

model PromoRedemption {
  id          String    @id @default(cuid())
