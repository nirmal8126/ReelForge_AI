generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String?   @map("password_hash")
  avatarUrl        String?   @map("avatar_url") @db.VarChar(500)
  role             UserRole  @default(USER)
  isActive         Boolean   @default(true) @map("is_active")
  emailVerified    DateTime? @map("email_verified")
  stripeCustomerId String?   @unique @map("stripe_customer_id") @db.VarChar(100)
  country          String?   @db.VarChar(2) // ISO 3166-1 alpha-2 (e.g., "IN", "US")

  // Referral fields
  referralCode     String       @unique @map("referral_code") @db.VarChar(12)
  referredByUserId String?      @map("referred_by_user_id")
  referredBy       User?        @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referredUsers    User[]       @relation("UserReferrals")
  referralTier     ReferralTier @default(FREE) @map("referral_tier")
  totalReferrals   Int          @default(0) @map("total_referrals")

  // Credits
  creditsBalance     Int    @default(0) @map("credits_balance")
  cashPendingCents   BigInt @default(0) @map("cash_pending_cents")
  cashWithdrawnCents BigInt @default(0) @map("cash_withdrawn_cents")

  // Relations
  subscription       Subscription?
  reelJobs           ReelJob[]
  longFormJobs       LongFormJob[]
  channelProfiles    ChannelProfile[]
  youtubeConnection  YouTubeConnection?
  autopilotSchedules AutopilotSchedule[]
  contentCalendar    ContentCalendar[]
  referralsMade      Referral[]          @relation("ReferrerReferrals")
  referralsReceived  Referral[]          @relation("ReferredReferrals")
  creditTransactions CreditTransaction[]
  mediaAssets        MediaAsset[]
  cartoonSeries      CartoonSeries[]
  quoteJobs          QuoteJob[]
  challengeJobs      ChallengeJob[]
  accounts           Account[]
  sessions           Session[]
  notifications      Notification[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([referredByUserId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique @map("user_id")
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  jobsLimit            Int                @default(3) @map("jobs_limit")
  jobsUsed             Int                @default(0) @map("jobs_used")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id") @db.VarChar(100)
  stripePriceId        String?            @map("stripe_price_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model ReelJob {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  channelProfileId String?       @map("channel_profile_id")
  seriesId         String?       @map("series_id")
  title            String        @db.VarChar(255)
  prompt           String        @db.Text
  script           String?       @db.Text
  style            String?       @db.VarChar(100)
  language         String?       @default("hi") @map("language") @db.VarChar(10)
  durationSeconds  Int           @default(30) @map("duration_seconds")
  aspectRatio      String        @default("9:16") @map("aspect_ratio") @db.VarChar(10)
  status           ReelJobStatus @default(QUEUED)
  outputUrl        String?       @map("output_url") @db.VarChar(500)
  thumbnailUrl     String?       @map("thumbnail_url") @db.VarChar(500)
  platformOutputs  Json?         @map("platform_outputs")
  aiProvider       String?       @map("ai_provider") @db.VarChar(50)
  voiceId          String?       @map("voice_id") @db.VarChar(100)
  musicGenre       String?       @map("music_genre") @db.VarChar(50)
  captionStyle     String?       @map("caption_style") @db.VarChar(50)
  errorMessage     String?       @map("error_message") @db.Text
  processingTimeMs Int?          @map("processing_time_ms")
  creditsCost      Int           @default(1) @map("credits_cost")

  user           User            @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  channelProfile ChannelProfile? @relation(fields: [channelProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  series         ContentSeries?  @relation(fields: [seriesId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([userId])
  @@index([channelProfileId])
  @@index([seriesId])
  @@index([status])
  @@map("reel_jobs")
}

model ChannelProfile {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  name                String   @db.VarChar(150)
  platform            Platform @default(MULTI)
  niche               String   @db.VarChar(100)
  tone                Tone     @default(PROFESSIONAL)
  primaryColor        String   @default("#6366F1") @map("primary_color") @db.VarChar(7)
  secondaryColor      String?  @map("secondary_color") @db.VarChar(7)
  fontFamily          String?  @map("font_family") @db.VarChar(100)
  captionStyle        String?  @map("caption_style") @db.VarChar(50)
  defaultVoiceId      String?  @map("default_voice_id") @db.VarChar(100)
  defaultLanguage     String?  @default("hi") @map("default_language") @db.VarChar(10)
  introAssetId        String?  @map("intro_asset_id")
  outroAssetId        String?  @map("outro_asset_id")
  logoUrl             String?  @map("logo_url") @db.VarChar(500)
  watermarkEnabled    Boolean  @default(false) @map("watermark_enabled")
  hookStyle           String?  @map("hook_style") @db.VarChar(50)
  ctaStyle            String?  @map("cta_style") @db.VarChar(50)
  musicPreference     String?  @map("music_preference") @db.VarChar(50)
  consistencyScore    Int      @default(0) @map("consistency_score")
  totalReelsGenerated Int      @default(0) @map("total_reels_generated")
  isDefault           Boolean  @default(false) @map("is_default")

  user               User                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  introAsset         MediaAsset?         @relation("IntroAsset", fields: [introAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  outroAsset         MediaAsset?         @relation("OutroAsset", fields: [outroAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reelJobs           ReelJob[]
  longFormJobs       LongFormJob[]
  contentSeries      ContentSeries[]
  autopilotSchedules AutopilotSchedule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([introAssetId])
  @@index([outroAssetId])
  @@map("channel_profiles")
}

model ContentSeries {
  id               String  @id @default(cuid())
  channelProfileId String  @map("channel_profile_id")
  name             String  @db.VarChar(150)
  description      String? @db.Text
  templatePrompt   String? @map("template_prompt") @db.Text
  episodeCount     Int     @default(0) @map("episode_count")

  channelProfile ChannelProfile @relation(fields: [channelProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reelJobs       ReelJob[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([channelProfileId])
  @@map("content_series")
}

model MediaAsset {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  type      MediaAssetType
  url       String         @db.VarChar(500)
  filename  String         @db.VarChar(255)
  sizeBytes BigInt         @map("size_bytes")
  mimeType  String         @map("mime_type") @db.VarChar(100)

  user                 User             @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  introChannelProfiles ChannelProfile[] @relation("IntroAsset")
  outroChannelProfiles ChannelProfile[] @relation("OutroAsset")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("media_assets")
}

model Referral {
  id                      String         @id @default(cuid())
  referrerUserId          String         @map("referrer_user_id")
  referredUserId          String         @map("referred_user_id")
  referralCodeUsed        String         @map("referral_code_used") @db.VarChar(12)
  status                  ReferralStatus @default(PENDING)
  convertedAt             DateTime?      @map("converted_at")
  conversionValueCents    Int            @default(0) @map("conversion_value_cents")
  referrerRewardCredits   Int            @default(0) @map("referrer_reward_credits")
  referrerRewardCashCents Int            @default(0) @map("referrer_reward_cash_cents")
  isPaid                  Boolean        @default(false) @map("is_paid")

  referrer User @relation("ReferrerReferrals", fields: [referrerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referred User @relation("ReferredReferrals", fields: [referredUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([referrerUserId])
  @@index([referredUserId])
  @@map("referrals")
}

model ReferralTierConfig {
  id                 String       @id @default(cuid())
  tier               ReferralTier @unique
  creditsPerReferral Int          @default(5) @map("credits_per_referral")
  cashPercent        Int          @default(0) @map("cash_percent")
  recurringPercent   Int          @default(0) @map("recurring_percent")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@map("referral_tier_configs")
}

model CreditTransaction {
  id           String                @id @default(cuid())
  userId       String                @map("user_id")
  amount       Int // positive = credit, negative = debit
  type         CreditTransactionType
  description  String?               @db.VarChar(255)
  referenceId  String?               @map("reference_id") @db.VarChar(255) // job id, referral id, etc.
  balanceAfter Int                   @map("balance_after")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("credit_transactions")
}

// Long-form video job (5-30 minutes)
model LongFormJob {
  id                  String  @id @default(cuid())
  userId              String  @map("user_id")
  channelProfileId    String? @map("channel_profile_id")
  seriesId            String? @map("series_id")
  autopilotScheduleId String? @map("autopilot_schedule_id")

  // Content details
  title           String  @db.VarChar(255)
  prompt          String  @db.Text
  script          String? @db.MediumText
  outline         Json? // Chapter structure
  durationMinutes Int     @default(10) @map("duration_minutes") // 5-30

  // Generation settings
  style       String? @db.VarChar(100)
  language    String  @default("hi") @map("language") @db.VarChar(10)
  voiceId     String? @map("voice_id") @db.VarChar(100)
  aspectRatio String  @default("16:9") @map("aspect_ratio") @db.VarChar(10)

  // Hybrid approach settings
  aiClipRatio      Float   @default(0.3) @map("ai_clip_ratio") // % of AI clips vs stock
  useStockFootage  Boolean @default(true) @map("use_stock_footage")
  useStaticVisuals Boolean @default(true) @map("use_static_visuals")

  // Status and progress
  status       LongFormJobStatus @default(QUEUED)
  progress     Int               @default(0) // 0-100
  currentStage String?           @map("current_stage") @db.VarChar(100)

  // Output
  outputUrl    String? @map("output_url") @db.VarChar(500)
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  // YouTube integration
  publishToYouTube Boolean        @default(false) @map("publish_to_youtube")
  youtubeVideoId   String?        @unique @map("youtube_video_id") @db.VarChar(100)
  youtubeStatus    YouTubeStatus? @map("youtube_status")

  // Metadata
  errorMessage       String? @map("error_message") @db.Text
  processingTimeMs   Int?    @map("processing_time_ms")
  creditsCost        Int     @default(5) @map("credits_cost")
  estimatedCostCents Int?    @map("estimated_cost_cents")

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  channelProfile    ChannelProfile?    @relation(fields: [channelProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  autopilotSchedule AutopilotSchedule? @relation(fields: [autopilotScheduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  segments          LongFormSegment[]
  youtubeMetadata   YouTubeMetadata?
  calendarEntry     ContentCalendar?

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([userId])
  @@index([channelProfileId])
  @@index([autopilotScheduleId])
  @@index([status])
  @@index([youtubeVideoId])
  @@map("long_form_jobs")
}

// Video segments (chapters/scenes)
model LongFormSegment {
  id            String @id @default(cuid())
  longFormJobId String @map("long_form_job_id")
  segmentIndex  Int    @map("segment_index")

  // Content
  title      String @db.VarChar(255)
  scriptText String @db.Text
  startTime  Float  @map("start_time") // seconds
  endTime    Float  @map("end_time")

  // Assets
  visualType    SegmentVisualType @map("visual_type") // AI_CLIP, STOCK_VIDEO, STATIC_IMAGE
  assetUrl      String?           @map("asset_url") @db.VarChar(500)
  assetMetadata Json?             @map("asset_metadata")

  // Editor metadata
  transitionType  String?  @default("none") @map("transition_type") @db.VarChar(20)
  captionsEnabled Boolean  @default(true) @map("captions_enabled")
  titleOverlay    Boolean  @default(false) @map("title_overlay")

  // Processing
  status       SegmentStatus @default(PENDING)
  errorMessage String?       @map("error_message") @db.Text

  longFormJob LongFormJob @relation(fields: [longFormJobId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([longFormJobId, segmentIndex])
  @@index([longFormJobId])
  @@map("long_form_segments")
}

// YouTube metadata and SEO
model YouTubeMetadata {
  id            String @id @default(cuid())
  longFormJobId String @unique @map("long_form_job_id")

  // Auto-generated SEO
  title       String @db.VarChar(100)
  description String @db.Text
  tags        Json // Array of strings
  category    String @db.VarChar(50)

  // Thumbnail
  thumbnailPath String? @map("thumbnail_path") @db.VarChar(500)

  // Publishing settings
  privacyStatus String    @default("private") @db.VarChar(20) // private, unlisted, public
  publishedAt   DateTime? @map("published_at")
  scheduledFor  DateTime? @map("scheduled_for")

  // Analytics (updated via YouTube API webhook)
  viewCount    Int       @default(0) @map("view_count")
  likeCount    Int       @default(0) @map("like_count")
  commentCount Int       @default(0) @map("comment_count")
  lastSyncedAt DateTime? @map("last_synced_at")

  longFormJob LongFormJob @relation(fields: [longFormJobId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("youtube_metadata")
}

// YouTube OAuth tokens
model YouTubeConnection {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  channelId    String @map("channel_id") @db.VarChar(100)
  channelTitle String @map("channel_title") @db.VarChar(255)

  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at")

  isActive Boolean @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("youtube_connections")
}

// Autopilot scheduling
model AutopilotSchedule {
  id               String @id @default(cuid())
  userId           String @map("user_id")
  channelProfileId String @map("channel_profile_id")

  name     String  @db.VarChar(150)
  isActive Boolean @default(true) @map("is_active")

  // Schedule settings
  frequency      AutopilotFrequency @default(WEEKLY)
  cronExpression String?            @map("cron_expression") @db.VarChar(100)
  timezone       String             @default("UTC") @db.VarChar(50)

  // Content generation
  useTrendingTopics  Boolean @default(false) @map("use_trending_topics")
  trendingCategories Json?   @map("trending_categories") // Array of categories to monitor
  customTopics       Json?   @map("custom_topics") // Predefined topic pool

  // Video settings (template)
  durationMinutes Int     @default(10) @map("duration_minutes")
  style           String? @db.VarChar(100)
  language        String  @default("hi") @db.VarChar(10)
  voiceId         String? @map("voice_id") @db.VarChar(100)

  // YouTube auto-publish
  autoPublish   Boolean @default(false) @map("auto_publish")
  publishDelay  Int     @default(0) @map("publish_delay") // minutes after generation
  privacyStatus String  @default("private") @db.VarChar(20)

  // Stats
  totalGenerated Int       @default(0) @map("total_generated")
  lastRunAt      DateTime? @map("last_run_at")
  nextRunAt      DateTime? @map("next_run_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  channelProfile  ChannelProfile    @relation(fields: [channelProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  longFormJobs    LongFormJob[]
  calendarEntries ContentCalendar[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([channelProfileId])
  @@index([isActive, nextRunAt])
  @@map("autopilot_schedules")
}

// Content calendar for manual planning
model ContentCalendar {
  id                  String  @id @default(cuid())
  userId              String  @map("user_id")
  autopilotScheduleId String? @map("autopilot_schedule_id")

  title         String   @db.VarChar(255)
  topic         String   @db.Text
  scheduledDate DateTime @map("scheduled_date")

  status        CalendarEntryStatus @default(PLANNED)
  longFormJobId String?             @unique @map("long_form_job_id")

  notes String? @db.Text

  user              User               @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  autopilotSchedule AutopilotSchedule? @relation(fields: [autopilotScheduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  longFormJob       LongFormJob?       @relation(fields: [longFormJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([autopilotScheduleId])
  @@index([scheduledDate])
  @@map("content_calendar")
}

// Trending topics cache
model TrendingTopic {
  id String @id @default(cuid())

  source   TrendingSource // GOOGLE_TRENDS, YOUTUBE, TIKTOK
  category String         @db.VarChar(100)
  keyword  String         @db.VarChar(255)

  // Metrics
  searchVolume Int?   @map("search_volume")
  growthRate   Float? @map("growth_rate")
  trendScore   Int    @default(0) @map("trend_score") // 0-100

  // Metadata
  relatedTopics Json?  @map("related_topics")
  region        String @default("US") @db.VarChar(10)

  // Freshness
  detectedAt DateTime @default(now()) @map("detected_at")
  expiresAt  DateTime @map("expires_at")

  @@unique([source, keyword, region])
  @@index([source, category])
  @@index([trendScore])
  @@index([expiresAt])
  @@map("trending_topics")
}

// Stock footage cache
model StockFootageCache {
  id String @id @default(cuid())

  provider   String @db.VarChar(50) // pexels, pixabay, storyblocks
  externalId String @map("external_id") @db.VarChar(255)

  query        String  @db.VarChar(255)
  url          String  @db.VarChar(500)
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  duration Int? // seconds
  width    Int?
  height   Int?

  metadata Json?

  downloadCount Int       @default(0) @map("download_count")
  lastUsedAt    DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([provider, externalId])
  @@index([query])
  @@map("stock_footage_cache")
}

// Quote generation jobs
model QuoteJob {
  id               String         @id @default(cuid())
  userId           String         @map("user_id")

  // Content
  quoteType        String         @default("image") @map("quote_type") @db.VarChar(10) // text | image
  prompt           String         @db.Text
  category         String         @db.VarChar(50)
  quoteText        String?        @map("quote_text") @db.Text
  author           String?        @db.VarChar(200)
  language         String         @default("hi") @db.VarChar(10)
  quoteVariations  String?        @map("quote_variations") @db.LongText // JSON array of {quote, author}

  // Visual settings (only for image type)
  bgType           String         @default("gradient") @map("bg_type") @db.VarChar(20)
  bgValue          String?        @map("bg_value") @db.VarChar(500)
  textColor        String         @default("#FFFFFF") @map("text_color") @db.VarChar(10)
  fontStyle        String         @default("serif") @map("font_style") @db.VarChar(30)
  aspectRatio      String         @default("1:1") @map("aspect_ratio") @db.VarChar(10)

  // Status & progress
  status           QuoteJobStatus @default(QUEUED)
  progress         Int            @default(0)
  currentStage     String?        @map("current_stage") @db.VarChar(50)

  // Output
  imageUrl         String?        @map("image_url") @db.VarChar(500)
  videoUrl         String?        @map("video_url") @db.VarChar(500)
  thumbnailUrl     String?        @map("thumbnail_url") @db.VarChar(500)

  // Metadata
  errorMessage     String?        @map("error_message") @db.Text
  creditsCost      Int            @default(1) @map("credits_cost")
  processingTimeMs Int?           @map("processing_time_ms")

  createdAt        DateTime       @default(now()) @map("created_at")
  completedAt      DateTime?      @map("completed_at")

  user             User           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
  @@map("quote_jobs")
}

// Cartoon Studio models
model CartoonSeries {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  targetAudience  String?  @map("target_audience") @db.VarChar(100)
  artStyle        String?  @map("art_style") @db.VarChar(50)
  narratorVoiceId String?  @map("narrator_voice_id") @db.VarChar(100)
  language        String   @default("hi") @db.VarChar(10)
  aspectRatio     String   @default("16:9") @map("aspect_ratio") @db.VarChar(10)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters CartoonCharacter[]
  episodes   CartoonEpisode[]

  @@index([userId])
  @@map("cartoon_series")
}

model CartoonCharacter {
  id                String   @id @default(cuid())
  seriesId          String   @map("series_id")
  name              String   @db.VarChar(100)
  description       String?  @db.Text
  personality       String?  @db.Text
  voiceId           String?  @map("voice_id") @db.VarChar(100)
  referenceImageUrl String?  @map("reference_image_url") @db.VarChar(500)
  color             String?  @db.VarChar(7)
  createdAt         DateTime @default(now()) @map("created_at")

  series CartoonSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@index([seriesId])
  @@map("cartoon_characters")
}

model CartoonEpisode {
  id               String               @id @default(cuid())
  seriesId         String               @map("series_id")
  title            String               @db.VarChar(300)
  synopsis         String?              @db.Text
  episodeNumber    Int                  @map("episode_number")
  prompt           String               @db.Text
  storyScript      String?              @map("story_script") @db.LongText
  status           CartoonEpisodeStatus @default(QUEUED)
  progress         Int                  @default(0)
  currentStage     String?              @map("current_stage") @db.VarChar(50)
  outputUrl        String?              @map("output_url") @db.VarChar(500)
  thumbnailUrl     String?              @map("thumbnail_url") @db.VarChar(500)
  errorMessage     String?              @map("error_message") @db.Text
  creditsCost      Int                  @default(0) @map("credits_cost")
  processingTimeMs Int?                 @map("processing_time_ms")
  durationSeconds  Int?                 @map("duration_seconds")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  series CartoonSeries  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  scenes CartoonScene[]

  @@unique([seriesId, episodeNumber])
  @@index([seriesId])
  @@index([status])
  @@map("cartoon_episodes")
}

model CartoonScene {
  id           String             @id @default(cuid())
  episodeId    String             @map("episode_id")
  sceneIndex   Int                @map("scene_index")
  description  String             @db.Text
  visualPrompt String?            @map("visual_prompt") @db.Text
  imageUrl     String?            @map("image_url") @db.VarChar(500)
  narration    String?            @db.Text
  dialogue     Json?              @db.Json
  startTime    Float              @default(0) @map("start_time")
  endTime      Float              @default(0) @map("end_time")
  status       CartoonSceneStatus @default(PENDING)
  createdAt    DateTime           @default(now()) @map("created_at")

  episode CartoonEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([episodeId, sceneIndex])
  @@index([episodeId])
  @@map("cartoon_scenes")
}

